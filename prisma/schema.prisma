generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int          @id @default(autoincrement())
  username         String       @unique
  passwordHash     String
  name             String
  createdAt        DateTime     @default(now())
  auditLogs        AuditLog[]
  failuresResolved FailureLog[]
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  contactName String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  vendors     Vendor[]
}

model Vendor {
  id                 Int            @id @default(autoincrement())
  name               String
  contactName        String?
  email              String?
  phone              String?
  shopifyVendorName  String?
  supplierId         Int?
  supplier           Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  invoices           Invoice[]
  credits            Credit[]
  auditLogs          AuditLog[]
  vendorProfile      VendorProfile?
}

model VendorProfile {
  id              String   @id @default(cuid())
  vendorId        Int      @unique
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  columnMappings  Json
  extractionHints Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id            Int               @id @default(autoincrement())
  invoiceNumber String
  vendor        Vendor            @relation(fields: [vendorId], references: [id])
  vendorId      Int
  status        InvoiceStatus     @default(ORDERED)
  invoiceDate   DateTime?
  paymentTerms  String?
  dueDate       DateTime?
  total         Decimal           @db.Decimal(10, 2)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lineItems     InvoiceLineItem[]
}

enum InvoiceStatus {
  ORDERED
  RECEIVED
  PAID
}

model InvoiceLineItem {
  id                     Int     @id @default(autoincrement())
  invoice                Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId              Int
  sku                    String?
  description            String
  quantityOrdered        Int
  quantityReceived       Int     @default(0)
  unitCost               Decimal  @db.Decimal(10, 2)
  retailPrice            Decimal? @db.Decimal(10, 2)
  hasDiscrepancy         Boolean  @default(false)
  receivingNote          String?
  barcode                String?
  shopifyProductTitle    String?
  shopifyVariantId       String?
  shopifyInventoryItemId String?
}

model Credit {
  id            Int      @id @default(autoincrement())
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  vendorId      Int
  amount        Decimal  @db.Decimal(10, 2)
  invoiceNumber String?
  notes         String?
  date          DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  action    String
  details   String?
  timestamp DateTime @default(now())
  vendorId  Int?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
}

model FailureLog {
  id           Int       @id @default(autoincrement())
  operation    String
  itemLabel    String
  errorMessage String
  occurredAt   DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById Int?
  resolvedBy   User?     @relation(fields: [resolvedById], references: [id])
}
