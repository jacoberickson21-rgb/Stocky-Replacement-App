generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int              @id @default(autoincrement())
  username         String           @unique
  passwordHash     String
  name             String
  createdAt        DateTime         @default(now())
  auditLogs        AuditLog[]
  failuresResolved FailureLog[]
  discrepancyLogs  DiscrepancyLog[]
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  contactName String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  vendors     Vendor[]
}

model Vendor {
  id                 Int              @id @default(autoincrement())
  name               String
  contactName        String?
  email              String?
  phone              String?
  shopifyVendorName  String?
  supplierId         Int?
  supplier           Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  invoices           Invoice[]
  credits            Credit[]
  auditLogs          AuditLog[]
  vendorProfile      VendorProfile?
  lineItems          InvoiceLineItem[]
  discrepancyLogs    DiscrepancyLog[]
}

model VendorProfile {
  id              String   @id @default(cuid())
  vendorId        Int      @unique
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  columnMappings  Json
  extractionHints Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id              Int               @id @default(autoincrement())
  invoiceNumber   String
  vendor          Vendor            @relation(fields: [vendorId], references: [id])
  vendorId        Int
  status          InvoiceStatus     @default(ORDERED)
  invoiceDate     DateTime?
  paymentTerms    String?
  dueDate         DateTime?
  total           Decimal           @db.Decimal(10, 2)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lineItems       InvoiceLineItem[]
  discrepancyLogs DiscrepancyLog[]
}

enum InvoiceStatus {
  ORDERED
  RECEIVED
  PAID
}

model InvoiceLineItem {
  id                     Int              @id @default(autoincrement())
  invoice                Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId              Int
  vendorId               Int?
  vendor                 Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  sku                    String?
  description            String
  quantityOrdered        Int
  quantityReceived       Int              @default(0)
  unitCost               Decimal          @db.Decimal(10, 2)
  retailPrice            Decimal?         @db.Decimal(10, 2)
  hasDiscrepancy         Boolean          @default(false)
  receivingNote          String?
  barcode                String?
  shopifyProductTitle    String?
  shopifyVariantId       String?
  shopifyInventoryItemId String?
  discrepancyLogs        DiscrepancyLog[]
}

model Credit {
  id            Int      @id @default(autoincrement())
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  vendorId      Int
  amount        Decimal  @db.Decimal(10, 2)
  invoiceNumber String?
  notes         String?
  date          DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  action    String
  details   String?
  timestamp DateTime @default(now())
  vendorId  Int?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
}

model FailureLog {
  id           Int       @id @default(autoincrement())
  operation    String
  itemLabel    String
  errorMessage String
  occurredAt   DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById Int?
  resolvedBy   User?     @relation(fields: [resolvedById], references: [id])
}

model DiscrepancyLog {
  id                Int             @id @default(autoincrement())
  invoiceLineItemId Int
  invoiceLineItem   InvoiceLineItem @relation(fields: [invoiceLineItemId], references: [id], onDelete: Cascade)
  invoiceId         Int
  invoice           Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  vendorId          Int
  vendor            Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  sku               String?
  expectedQty       Int
  actualQty         Int
  note              String?
  staffId           Int
  staff             User            @relation(fields: [staffId], references: [id])
  createdAt         DateTime        @default(now())
}

model AppSetting {
  key   String @id
  value String
}

enum SyncStatus {
  RUNNING
  COMPLETE
  ERROR
}

model ProductCache {
  id               String   @id @default(cuid())
  variantId        String   @unique
  productId        String
  title            String
  variantTitle     String
  sku              String?
  barcode          String?
  vendor           String?
  productType      String?
  tags             String[]
  price            Decimal  @db.Decimal(10, 2)
  cost             Decimal? @db.Decimal(10, 2)
  currentInventory Int
  imageUrl         String?
  status           String   @default("ACTIVE")
  syncedAt         DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SalesCache {
  id        String   @id @default(cuid())
  variantId String
  sku       String?
  date      DateTime
  unitsSold Int
  revenue   Decimal  @db.Decimal(10, 2)

  @@unique([variantId, date])
}

model SyncLog {
  id              String     @id @default(cuid())
  status          SyncStatus
  startedAt       DateTime   @default(now())
  completedAt     DateTime?
  durationMs      Int?
  variantsSynced  Int?
  salesDaysSynced Int?
  totalVariants   Int?
  currentVariant  Int?
  errorMessage    String?
}
